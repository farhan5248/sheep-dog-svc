<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <property name="LOG_LEVEL" value="${LOG_LEVEL:-INFO}" />
    <property name="LOG_PATH" value="${LOG_PATH:-/logs}" />

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!--
      Dedicated file for test-infrastructure DEBUG output (TestObject /
      MavenTestObject / CommandFake / *RunnerFake). Kept separate from:
        - DarmokMojoLog (target/darmok/darmok.mojo.log)
        - Runner log (target/darmok/darmok.runners.<date>.log)
        - log.txt (mvn invocation stdout)
        - mojo.event.log (FakeRunnerState tap)
      so spec assertions on those files never see test-infra DEBUG noise.
    -->
    <appender name="FAKE_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_PATH}/darmok-maven-plugin.test-fake.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${LOG_PATH}/darmok-maven-plugin.test-fake-%d{yyyy-MM-dd}.log.gz</fileNamePattern>
            <maxHistory>1</maxHistory>
            <totalSizeCap>1GB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <root level="${LOG_LEVEL}">
        <appender-ref ref="CONSOLE" />
    </root>

    <logger name="org.farhan.common" level="DEBUG" additivity="false">
        <appender-ref ref="FAKE_FILE" />
    </logger>
    <logger name="org.farhan.fake" level="DEBUG" additivity="false">
        <appender-ref ref="FAKE_FILE" />
    </logger>

    <logger name="org.springframework" level="INFO" />
    <logger name="io.cucumber" level="INFO" />
</configuration>
